par -w -intstyle ise -ol high -xe n -mt off topmod_map.ncd topmod.ncd topmod.pcf 
trce -intstyle ise -v 3 -s 2 -n 3 -fastpaths -xml topmod.twx topmod.ncd -o topmod.twr topmod.pcf -ucf port.ucf 
bitgen -intstyle ise -f topmod.ut topmod.ncd 
